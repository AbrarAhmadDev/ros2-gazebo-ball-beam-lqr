<?xml version="1.0"?>
<robot name="ball_beam" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- =========================================================== -->
  <!-- Gazebo / ros2_control plugin                                 -->
  <!-- =========================================================== -->

  <ros2_control name="GazeboSystem" type="system">
    <hardware>
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
    </hardware>

    <!-- Beam joint: position-controlled -->
    <joint name="beam_joint">
      <command_interface name="position">
        <param name="min">-0.4</param>
        <param name="max"> 0.4</param>
      </command_interface>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>

    <!-- Ball joint: passive (read position/velocity only) -->
    <joint name="ball_joint">
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>
<!--
  <gazebo>
    <plugin filename="gz_ros2_control-system"
            name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>/home/legendabrar/ros2_ws/src/ball_balancer/config/controllers.yaml</parameters>
      <ros>
        <remapping>~/robot_description:=/robot_description</remapping>
      </ros>
    </plugin>
  </gazebo>
-->
<!--
<gazebo>
  <plugin filename="gz_ros2_control-system"
          name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <parameters>/home/legendabrar/ros2_ws/src/ball_balancer/config/controllers.yaml</parameters>
    <controller_manager_node_name>controller_manager</controller_manager_node_name>
  </plugin>
</gazebo>
-->
<gazebo>
  <plugin filename="libgz_ros2_control-system.so"
          name="gz_ros2_control::GazeboSimROS2ControlPlugin">
    <!-- <parameters>/home/legendabrar/ros2_ws/src/ball_balancer/config/controllers.yaml</parameters> -->
    <parameters>$(find ball_balancer)/config/controllers.yaml</parameters>
  </plugin>
</gazebo>
  <!-- =========================================================== -->
  <!-- BASE PLATE                                                   -->
  <!-- =========================================================== -->

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.35 0.05"/>
      </geometry>
      <material name="gray">
        <color rgba="0.45 0.45 0.45 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.35 0.35 0.05"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="5.0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.08"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- =========================================================== -->
  <!-- SUPPORT PILLAR                                               -->
  <!-- Visually bridges the gap between base and beam pivot        -->
  <!-- =========================================================== -->

  <link name="pillar_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <!-- height = 0.175 m  (sits from base top to beam pivot)  -->
        <cylinder radius="0.025" length="0.175"/>
      </geometry>
      <material name="dark_gray">
        <color rgba="0.3 0.3 0.3 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.025" length="0.175"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.002" iyy="0.002" izz="0.0003"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- Fixed joint: base_link → pillar                            -->
  <!-- Centre of pillar is at z = base_top + pillar_half          -->
  <!--   base_top  = 0.025  (half of 0.05)                        -->
  <!--   pillar_half = 0.0875                                      -->
  <!--   total offset = 0.025 + 0.0875 = 0.1125                   -->
  <joint name="pillar_joint" type="fixed">
    <parent link="base_link"/>
    <child  link="pillar_link"/>
    <origin xyz="0 0 0.1125" rpy="0 0 0"/>
  </joint>

  <!-- =========================================================== -->
  <!-- BEAM                                                         -->
  <!-- =========================================================== -->

  <link name="beam_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 0.06 0.025"/>
      </geometry>
      <material name="blue">
        <color rgba="0.1 0.3 0.9 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="1.0 0.06 0.025"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.8"/>
      <!-- Thin rod along x: Ixx small, Iyy≈Izz≈mL²/12 -->
      <inertia ixx="0.002" iyy="0.067" izz="0.067"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- Revolute joint: pillar_top → beam pivot                     -->
  <!-- Pillar top = pillar_centre + pillar_half = 0.1125+0.0875    -->
  <!--            = 0.2 m above base_link origin                   -->
  <!-- We reference from pillar_link, so offset = +pillar_half     -->
  <joint name="beam_joint" type="revolute">
    <parent link="pillar_link"/>
    <child  link="beam_link"/>
    <!-- top of pillar relative to pillar centre -->
    <origin xyz="0 0 0.0875" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-0.4" upper="0.4" effort="50" velocity="2.0"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <!-- =========================================================== -->
  <!-- BALL                                                         -->
  <!-- =========================================================== -->

  <link name="ball_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
      <material name="red">
        <color rgba="0.9 0.1 0.1 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <sphere radius="0.025"/>
      </geometry>
    </collision>
    <inertial>
      <origin xyz="0 0 0"/>
      <mass value="0.1"/>
      <!-- Solid sphere: I = 2/5 * m * r² -->
      <inertia ixx="0.00001" iyy="0.00001" izz="0.00001"
               ixy="0.0" ixz="0.0" iyz="0.0"/>
    </inertial>
  </link>

  <!-- Prismatic joint along beam (x-axis) so ball slides           -->
  <!-- Ball rests on top of beam: offset z = beam_half + ball_r    -->
  <!--   beam_half = 0.0125,  ball_r = 0.025  → 0.0375            -->
  <joint name="ball_joint" type="prismatic">
    <parent link="beam_link"/>
    <child  link="ball_link"/>
    <origin xyz="0 0 0.0375" rpy="0 0 0"/>
    <axis xyz="1 0 0"/>
    <limit lower="-0.45" upper="0.45" effort="0.0" velocity="5.0"/>
    <dynamics damping="0.05" friction="0.01"/>
  </joint>

</robot>
